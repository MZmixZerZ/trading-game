# ===== Frontend (React) =====
# Supabase
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key

# Backend API base URL (leave empty for same-origin, set for cross-origin)
REACT_APP_API_BASE_URL=http://localhost:5000

# Socket.IO server URL (optional, defaults to API_BASE_URL)
REACT_APP_SOCKET_URL=http://localhost:5000

# ===== Backend / Server =====
PORT=5000
NODE_ENV=production
JWT_SECRET=replace_with_secret

# Supabase (service role for server-side operations)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Third-party keys
GOOGLE_API_KEY=
YAHOO_FINANCE_API_KEY=

# App URLs
CLIENT_URL=http://localhost:3000
FRONTEND_URL=

# Note: Do NOT commit real secrets. Use your hosting provider's secret manager.
