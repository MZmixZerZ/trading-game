# Frontend (React) - prefix with REACT_APP_
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=
REACT_APP_FIREBASE_MEASUREMENT_ID=

# Backend / Server
PORT=5000
NODE_ENV=production
JWT_SECRET=replace_with_secret

# Firebase admin (if using service account via env)
# FIREBASE_SERVICE_ACCOUNT_JSON should be stored securely (or uploaded to hosting provider secrets)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Database (if migrating to Supabase/Postgres)
DATABASE_URL=postgres://user:password@host:5432/dbname
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Third-party keys
GOOGLE_API_KEY=
YAHOO_FINANCE_API_KEY=

# App URLs
CLIENT_URL=http://localhost:3000
FRONTEND_URL=

# Optional: Sentry / Monitoring
SENTRY_DSN=

# Note: Do NOT commit real secrets. Use your hosting provider's secret manager.
