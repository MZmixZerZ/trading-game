{
  "name": "streaming-ideatrade-server",
  "version": "1.0.0",
  "description": "Backend API server for Streaming IdeaTrade",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "check": "node -c server.js",
    "migrate:firestore-to-supabase": "node tools/migrate_firestore_to_supabase.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:start:prod": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop streaming-ideatrade-server",
    "pm2:restart": "pm2 restart streaming-ideatrade-server",
    "pm2:reload": "pm2 reload streaming-ideatrade-server",
    "pm2:logs": "pm2 logs streaming-ideatrade-server",
    "pm2:monit": "pm2 monit",
    "pm2:delete": "pm2 delete streaming-ideatrade-server",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "express",
    "api",
    "socket.io",
    "finance",
    "trading"
  ],
  "author": "IdeaTrade Team",
  "license": "ISC",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.108.2",
    "cheerio": "^1.1.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "puppeteer": "^24.10.2",
    "socket.io": "^4.8.1",
    "uuid": "^11.1.0",
    "ws": "^8.21.0",
    "yahoo-finance2": "^2.13.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.0",
    "pm2": "^5.3.0"
  }
}
